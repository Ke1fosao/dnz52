# =============================================================================
# Шаблон змінних середовища ЗДО №52
# Скопіюйте цей файл як ".env" і заповніть своїми значеннями.
# Файл .env у git НЕ потрапляє (він у .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SECRET_KEY (ОБОВ'ЯЗКОВО згенерувати новий для продакшену!)
# -----------------------------------------------------------------------------
# Згенерувати новий ключ можна командою:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CHANGE-ME-on-production


# -----------------------------------------------------------------------------
# 2. DEBUG
# -----------------------------------------------------------------------------
# True — на локальному комп'ютері (показуються помилки, працює статика без collectstatic)
# False — у продакшені (інакше це дуже небезпечно!)
DEBUG=True


# -----------------------------------------------------------------------------
# 3. ALLOWED_HOSTS
# -----------------------------------------------------------------------------
# Через кому, без пробілів. Додайте сюди ваш домен.
# Приклад для PythonAnywhere: dnz52.pythonanywhere.com,localhost,127.0.0.1
# Приклад для Render: dnz52.onrender.com,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1


# -----------------------------------------------------------------------------
# 4. CSRF_TRUSTED_ORIGINS (для HTTPS у продакшені)
# -----------------------------------------------------------------------------
# Тільки повні URL з https://, через кому
# Приклад: https://dnz52.pythonanywhere.com,https://dnz52.com.ua
CSRF_TRUSTED_ORIGINS=


# -----------------------------------------------------------------------------
# 5. DATABASE_URL (тільки для Render/Railway/Heroku — НЕ для PythonAnywhere)
# -----------------------------------------------------------------------------
# На PythonAnywhere НЕ потрібно — там використовується SQLite за замовчуванням.
# Render автоматично передасть цю змінну, якщо ви підключите Postgres.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
