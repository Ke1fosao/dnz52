# =============================================================================
# .gitignore — файли, які НЕ потрапляють у git
# =============================================================================

# -----------------------------------------------------------------------------
# Секрети та локальні налаштування (НІКОЛИ не комітити!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
local_settings.py
*.pem
*.key

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/

# Віртуальні середовища
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
*.log

# База даних (для PythonAnywhere — закоментуйте db.sqlite3 якщо хочете
# залити початкові дані одразу. Або краще використовуйте dumpdata/loaddata.)
db.sqlite3
db.sqlite3-journal

# Зібрана статика (генерується автоматично через collectstatic)
staticfiles/

# Завантажені користувачами файли (фото, документи)
# ⚠️ Якщо хочете перенести існуючі фото на хостинг — закоментуйте цей рядок
# і додайте media/ через `git add -f media/`
media/

# Локальні службові папки оптимізації медіа — не для GitHub
media-optimized/
media-parts/

# Локальні скрипти-помічники (не потрібні в репозиторії)
make_archives.py
optimize_media.py
verify_media.py

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Тимчасові файли проекту
# -----------------------------------------------------------------------------
seed_*.py
check_*.py
extract_*.py
data.json
backup-*.json
*.tar.gz
